<?xml version="1.0"?>
<ruleset name="SimpleWPHelpdesk">
    <description>Custom Ruleset for my plugin</description>

    <!-- Scan all PHP files in this folder -->
    <file>.</file>
    
    <!-- Ignore vendor and node_modules folders -->
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>

    <!-- Use the WordPress Standard -->
    <rule ref="WordPress">
        <!-- Ignore the rule that requires comments on every function/class -->
        <exclude name="Squiz.Commenting.FunctionComment.Missing"/>
        <exclude name="Squiz.Commenting.FileComment.Missing"/>
        <exclude name="Squiz.Commenting.ClassComment.Missing"/>
        <exclude name="Squiz.Commenting.VariableComment.Missing"/>
        <exclude name="Squiz.Commenting.InlineComment.InvalidEndChar"/>
        <exclude name="Squiz.Commenting.FunctionComment.WrongStyle"/>
        
        <!-- Ignore the rule about class file naming (class-xxx.php) -->
        <exclude name="WordPress.Files.FileName.InvalidClassFileName"/>
        <exclude name="WordPress.Files.FileName.NotHyphenatedLowercase"/>
        
        <!-- Ignore the rule about mixing classes and functions in one file -->
        <exclude name="Generic.Files.OneObjectStructurePerFile.MultipleFound"/>
    </rule>
</ruleset>