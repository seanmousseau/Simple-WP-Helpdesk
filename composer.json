{
    "require-dev": {
        "szepeviktor/phpstan-wordpress": "^2.0",
        "php-stubs/wordpress-stubs": "^6.9",
        "squizlabs/php_codesniffer": "^3.7",
        "wp-coding-standards/wpcs": "^3.0",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "phpunit/phpunit": "^9.6",
        "10up/wp_mock": "^1.0"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "scripts": {
        "post-install-cmd": ["@php -r \"if (is_dir('.git')) { exec('git config core.hooksPath .githooks'); }\""],
        "post-update-cmd": ["@php -r \"if (is_dir('.git')) { exec('git config core.hooksPath .githooks'); }\""]
    }
}
