# Simple WP Helpdesk — Test Environment Variables
# Copy to testing/.env and fill in your values.
# testing/.env is gitignored; this file is safe to commit.

# ── WordPress URLs ─────────────────────────────────────────────────────────────
WP_URL=https://example.com
WP_LOGIN_URL=https://example.com/wp-login.php
WP_ADMIN_URL=https://example.com/wp-admin/
WP_SUBMIT_PAGE=https://example.com/submit-ticket/
WP_PORTAL_PAGE=https://example.com/helpdesk/

# ── Admin credentials ──────────────────────────────────────────────────────────
WP_ADMIN_USER=admin
WP_ADMIN_PASS=changeme

# ── Technician 1 (full access) ─────────────────────────────────────────────────
WP_TECH1_EMAIL=tech1@example.com
WP_TECH1_USER=tech1
WP_TECH1_PASS=changeme

# ── Technician 2 (restricted) ──────────────────────────────────────────────────
WP_TECH2_USER=tech2
WP_TECH2_PASS=changeme

# ── Guest client (no WP account — tickets submitted via public form) ───────────
CLIENT1_NAME=Test Client One
CLIENT1_EMAIL=client1@example.com

CLIENT2_NAME=Test Client Two
CLIENT2_EMAIL=client2@example.com

# ── WP-CLI execution mode ──────────────────────────────────────────────────────
# "ssh"    — SSH to SSH_HOST, then docker exec into WP_CONTAINER (default, local dev)
# "docker" — docker compose exec on the local docker-compose.test.yml stack (CI / local Docker)
WP_MODE=ssh

# ── SSH mode (required when WP_MODE=ssh) ──────────────────────────────────────
SSH_HOST=192.168.80.15
WP_CONTAINER=wp-helpdesk-apache-1
WP_PATH=/var/www/html

# ── Docker mode (used when WP_MODE=docker; defaults match docker-compose.test.yml) ──
# WP_CONTAINER=wpcli
# WP_PATH=/var/www/html
# WP_URL=http://localhost:8080
# WP_LOGIN_URL=http://localhost:8080/wp-login.php
# WP_ADMIN_URL=http://localhost:8080/wp-admin/
# WP_SUBMIT_PAGE=http://localhost:8080/submit-a-ticket/
# WP_PORTAL_PAGE=http://localhost:8080/helpdesk-portal/
